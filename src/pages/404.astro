---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到" description="您请求的页面不存在。" canonicalPath="/404">
  <section class="flex min-h-[50vh] flex-col items-center justify-center px-4 py-16 text-center">
    <h1 class="text-6xl font-bold text-primary-dark">404</h1>
    <p class="mt-4 text-xl text-muted">页面未找到</p>
    <a href="/" class="btn btn-primary mt-8">返回首页</a>
  </section>
</BaseLayout>
