---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="视频"
  description="YouTube 上的 Openterface 产品演示、教程和测评。"
  canonicalPath="/videos/"
>
  <DocLinkBanner message="在我们迁移视频库期间，您可以访问旧版网站查看完整的 YouTube 视频列表。" />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl font-bold">视频</h1>
      <p class="mt-4 text-lg text-muted">
        观看 Openterface KVM 和 KeyMod 产品的演示、设置指南及社区测评。
      </p>
      <a href={legacyPath('/videos/')} class="btn btn-primary mt-8" target="_blank" rel="noopener">
        浏览所有视频 →
      </a>
    </div>
  </section>
</BaseLayout>
