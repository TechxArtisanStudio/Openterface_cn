---
import { docsPath, siteConfig } from '../config/site';
import Logo from './Logo.astro';
---

<footer class="border-t border-gray-200 bg-surface">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <Logo variant="default" class="h-7" />
        <p class="mt-3 text-sm text-muted">专为 IT 专业人士打造的超紧凑 KVM-over-USB 解决方案。</p>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-ink">产品</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/products/keymod/" class="text-muted hover:text-primary-dark">KeyMod 系列</a></li>
          <li><a href="/products/kvm-go/" class="text-muted hover:text-primary-dark">KVM-GO 系列</a></li>
          <li><a href="/products/minikvm/" class="text-muted hover:text-primary-dark">Mini-KVM</a></li>
          <li><a href="/products/accessories/" class="text-muted hover:text-primary-dark">配件</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-ink">资源</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/videos/" class="text-muted hover:text-primary-dark">视频</a></li>
          <li><a href={docsPath('/faq/')} class="text-muted hover:text-primary-dark" target="_blank" rel="noopener">常见问题</a></li>
          <li><a href={docsPath('/app/overview/')} class="text-muted hover:text-primary-dark" target="_blank" rel="noopener">应用</a></li>
          <li><a href={docsPath('/support/')} class="text-muted hover:text-primary-dark" target="_blank" rel="noopener">支持</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-8 border-t border-gray-200 pt-6 text-center text-xs text-muted">
      <p>© {new Date().getFullYear()} Openterface. 开源 KVM-over-USB。</p>
      <p class="mt-1">
        <a href={siteConfig.legacyUrl + '/policy/privacy/'} class="hover:text-primary-dark" target="_blank" rel="noopener">隐私政策</a>
        ·
        <a href={siteConfig.legacyUrl + '/policy/terms-of-service/'} class="hover:text-primary-dark" target="_blank" rel="noopener">服务条款</a>
        {siteConfig.analytics.enabled && (
          <>
            ·
            <a href="#" id="cookie-settings" class="hover:text-primary-dark">{siteConfig.analytics.consent.cookieLabel}</a>
          </>
        )}
      </p>
    </div>
  </div>
</footer>
